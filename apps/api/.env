# Локальный .env для запуска API напрямую (не в Docker)
# Postgres и Redis запущены через docker compose — слушают на localhost

DATABASE_URL=postgresql+asyncpg://rumi:changeme_in_production@localhost:5432/rumi_db
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-key-replace-in-production-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=rumi-files
S3_REGION=ru-central1

FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
ENVIRONMENT=development
