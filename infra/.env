# ============================
# PostgreSQL
# ============================
POSTGRES_USER=rumi
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=rumi_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rumi:changeme_in_production@postgres:5432/rumi_db

# ============================
# Redis
# ============================
REDIS_URL=redis://redis:6379/0

# ============================
# JWT — сгенерируй: python -c "import secrets; print(secrets.token_hex(64))"
# ============================
JWT_SECRET=replace-with-long-random-string-min-64-chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# ============================
# Yandex Object Storage (S3-совместимый)
# Создать в консоли Yandex Cloud → Object Storage
# ============================
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=rumi-files
S3_REGION=ru-central1

# ============================
# Qdrant (векторная БД)
# ============================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rumi_products

# ============================
# ЮКасса — платёжная система
# Зарегистрироваться на yookassa.ru
# ============================
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# ============================
# Email (SMTP через Яндекс 360)
# ============================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@rumi.design
SMTP_PASSWORD=your-smtp-password

# ============================
# Пути к AI-моделям (на GPU-сервере)
# ============================
FLUX_MODEL_PATH=/models/flux-1-dev
CONTROLNET_MODEL_PATH=/models/controlnet-depth
CLIP_MODEL_PATH=/models/clip-vit-l-14

# ============================
# Общее
# ============================
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
ENVIRONMENT=development
